---
interface Props {
  icon: string;
  title: string;
  description: string;
  tags: string[];
}
const { icon, title, description, tags } = Astro.props;
---

<div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6 bg-white dark:bg-slate-800/50 hover:border-accent-400 dark:hover:border-accent-500 transition-colors group">
  <div class="text-3xl mb-4">{icon}</div>
  <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100 mb-2 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
    {title}
  </h3>
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">{description}</p>
  <div class="flex flex-wrap gap-1.5">
    {tags.map((tag) => (
      <span class="px-2 py-0.5 rounded text-xs font-mono bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
        {tag}
      </span>
    ))}
  </div>
</div>
