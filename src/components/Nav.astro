---
const pathname = Astro.url.pathname;

const links = [
  { href: '/',           label: 'Home' },
  { href: '/consulting', label: 'Consulting' },
  { href: '/projects',   label: 'Projects' },
  { href: '/experience', label: 'Experience' },
  { href: '/speaking',   label: 'Speaking' },
  { href: '/contact',    label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/90 dark:bg-slate-900/90 backdrop-blur border-b border-slate-200 dark:border-slate-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="font-mono font-semibold text-accent-600 dark:text-accent-400 text-lg tracking-tight hover:opacity-80 transition-opacity">
      AD
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-1">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
              isActive(href)
                ? 'text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/30'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        aria-label="Toggle dark mode"
        class="p-2 rounded-md text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <!-- Sun icon -->
        <svg class="w-5 h-5 hidden dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <!-- Moon icon -->
        <svg class="w-5 h-5 block dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        aria-label="Open menu"
        class="md:hidden p-2 rounded-md text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
      >
        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900">
    <ul class="flex flex-col px-4 py-2 gap-1">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
              isActive(href)
                ? 'text-accent-600 dark:text-accent-400 bg-accent-50 dark:bg-accent-900/30'
                : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>
