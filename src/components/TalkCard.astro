---
interface Props {
  title: string;
  event: string;
  date: string;
  abstract: string;
  link?: string;
}
const { title, event, date, abstract, link } = Astro.props;
---

<article class="rounded-xl border border-slate-200 dark:border-slate-700 p-6 bg-white dark:bg-slate-800/50">
  <div class="flex flex-wrap items-center justify-between gap-2 mb-1">
    <p class="text-xs font-mono text-accent-600 dark:text-accent-400">{event}</p>
    <time class="text-xs text-slate-400 dark:text-slate-500 font-mono">{date}</time>
  </div>
  <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100 mb-3">{title}</h3>
  <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{abstract}</p>
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block mt-4 text-sm font-medium text-accent-600 dark:text-accent-400 hover:underline"
    >
      View recording →
    </a>
  )}
</article>
