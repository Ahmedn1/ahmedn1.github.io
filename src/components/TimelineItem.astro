---
interface Props {
  title: string;
  company: string;
  location: string;
  period: string;
  current?: boolean;
  bullets: string[];
  last?: boolean;
}
const { title, company, location, period, current, bullets, last } = Astro.props;
---

<div class="relative flex gap-6">
  <!-- Timeline spine -->
  <div class="flex flex-col items-center">
    <div class:list={[
      'w-3 h-3 rounded-full mt-1.5 ring-2 ring-white dark:ring-slate-900 shrink-0',
      current ? 'bg-accent-500' : 'bg-slate-300 dark:bg-slate-600',
    ]}></div>
    {!last && <div class="w-px bg-slate-200 dark:bg-slate-700 flex-1 mt-1"></div>}
  </div>

  <!-- Content -->
  <div class="pb-10">
    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 mb-1">
      <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">{title}</h3>
      {current && (
        <span class="px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300">
          Current
        </span>
      )}
    </div>
    <p class="text-sm text-slate-600 dark:text-slate-400 mb-0.5">
      <span class="font-medium">{company}</span>
      <span class="text-slate-400 dark:text-slate-500"> · </span>
      {location}
    </p>
    <p class="text-xs font-mono text-slate-400 dark:text-slate-500 mb-3">{period}</p>
    <ul class="space-y-1.5">
      {bullets.map((b) => (
        <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
          <span class="text-accent-500 mt-0.5 shrink-0">›</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
