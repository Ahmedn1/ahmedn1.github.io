---
import Base from '@/layouts/Base.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { projects } from '@/data/projects';

const featuredProjects = projects.filter((p) => p.featured);

const stats = [
  { value: '17+', label: 'Years of\nSoftware Engineering' },
  { value: '12+', label: 'Years of\nMachine Learning' },
  { value: 'Fulbright', label: 'Foreign Student\nScholar' },
  { value: 'GLG', label: 'Expert\nNetwork Member' },
];

const socials = [
  { label: 'LinkedIn',     href: 'https://www.linkedin.com/in/ahmedn1/' },
  { label: 'GitHub',       href: 'https://github.com/Ahmedn1' },
  { label: 'ResearchGate', href: 'https://www.researchgate.net/profile/Ahmed_Dawod' },
];

const teaser = [
  { icon: '📊', title: 'Traditional ML & Data Science', description: 'The right model for your problem — gradient boosting, statistical analysis, survival models, clustering — not just the trendiest approach.' },
  { icon: '🛍️', title: 'Recommender Systems', description: 'Large-scale recommendation engines, ranking systems, and personalization pipelines for e-commerce and consumer apps.' },
  { icon: '🤖', title: 'LLM & Agentic AI', description: 'RAG pipelines, fine-tuning, evaluation frameworks, and production-grade agentic systems.' },
];
---

<Base
  title="Ahmed Dawod — Senior ML Engineer, Data Scientist & AI Consultant"
  description="Senior ML Engineer & Data Scientist with 12+ years of ML experience across recommender systems, LLMs, NLP, statistical analysis, CV, BCI, and FinTech. Available for consulting engagements."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-accent-50/40 dark:from-slate-900 dark:via-slate-900 dark:to-accent-950/20 pt-24 pb-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-accent-600 dark:text-accent-400 text-sm mb-4">Montreal, Canada</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 dark:text-white mb-4">
        Ahmed Dawod
      </h1>
      <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-300 font-light mb-6">
        Senior ML Engineer, Data Scientist &amp; AI Consultant
      </p>
      <p class="max-w-2xl text-lg text-slate-600 dark:text-slate-400 leading-relaxed mb-10">
        I apply machine learning to hard, high-impact problems — from large-scale e-commerce
        recommender systems and drug discovery to cancer diagnostics, content intelligence, and
        financial inclusion. 12+ years across traditional ML, statistical analysis, LLMs, Agentic AI,
        NLP, Computer Vision, BCI, and FinTech.
      </p>

      <div class="flex flex-wrap gap-3 mb-12">
        <a
          href="/contact"
          class="px-5 py-2.5 rounded-lg bg-accent-600 hover:bg-accent-700 text-white font-medium text-sm transition-colors shadow-sm"
        >
          Get in touch
        </a>
        <a
          href="/consulting"
          class="px-5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 font-medium text-sm transition-colors"
        >
          View consulting services
        </a>
      </div>

      <!-- Social links -->
      <div class="flex flex-wrap gap-4">
        {socials.map(({ label, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-slate-500 dark:text-slate-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors"
          >
            {label} ↗
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="border-y border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/30 py-8 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-6">
      {stats.map(({ value, label }) => (
        <div class="text-center">
          <p class="text-2xl font-semibold text-accent-600 dark:text-accent-400">{value}</p>
          <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 whitespace-pre-line leading-snug">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- About -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-20">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100 mb-6">About</h2>
    <div class="space-y-4 text-slate-600 dark:text-slate-400 leading-relaxed max-w-3xl">
      <p>
        I'm a Senior ML Engineer and Data Scientist with a passion for applying the right ML solution
        to the right problem. Currently at Shopify, I own and lead large-scale recommender system
        projects for the Shop app. Previously at BenchSci I built ML and LLM systems for drug
        discovery in the pharmaceutical domain. I also built one of the very first NLG content writers
        at MarketMuse, contributed to published cancer-diagnostic research at AOA Dx, and built
        alternative credit-scoring models for the unbanked at PayMob.
      </p>
      <p>
        Beyond full-time engineering, I consult independently — helping teams find the most effective
        ML solution for their problem, whether that's a rigorous statistical model, a classical
        ensemble, a recommender system, or an LLM pipeline. I don't default to the trendiest tool;
        I find what works. I'm also a member of the <strong class="font-medium text-slate-800 dark:text-slate-200">GLG Research Expert Network</strong>,
        available for expert calls on ML, data science, and AI system design.
      </p>
      <p>
        I hold an M.S. in Computer Science (ML focus) from Purdue University, funded by a
        Fulbright scholarship. My career started early — at 20 I was already building software
        professionally, and at 23 my computer vision and speech recognition system for quadriplegic
        patients won the Microsoft Imagine Cup in Egypt.
      </p>
    </div>
  </section>

  <!-- Consulting teaser -->
  <section class="bg-slate-50 dark:bg-slate-800/30 py-20 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-baseline justify-between gap-4 mb-10">
        <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">Consulting Services</h2>
        <a href="/consulting" class="text-sm text-accent-600 dark:text-accent-400 hover:underline shrink-0">All services →</a>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {teaser.map(({ icon, title, description }) => (
          <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-5 bg-white dark:bg-slate-800/50">
            <div class="text-2xl mb-3">{icon}</div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-1">{title}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-20">
    <div class="flex items-baseline justify-between gap-4 mb-10">
      <h2 class="text-2xl font-semibold text-slate-900 dark:text-slate-100">Featured Projects</h2>
      <a href="/projects" class="text-sm text-accent-600 dark:text-accent-400 hover:underline shrink-0">All projects →</a>
    </div>
    <div class="grid sm:grid-cols-2 gap-5">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <!-- CTA banner -->
  <section class="bg-accent-600 dark:bg-accent-700 py-16 px-4 sm:px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl font-semibold text-white mb-3">Let's work together</h2>
      <p class="text-accent-100 mb-8 leading-relaxed">
        Whether you need an ML strategy review, a production LLM system, or an expert consultation via GLG — I'm available.
      </p>
      <a
        href="/contact"
        class="inline-block px-6 py-3 rounded-lg bg-white text-accent-700 font-semibold text-sm hover:bg-accent-50 transition-colors shadow"
      >
        Get in touch
      </a>
    </div>
  </section>
</Base>
