---
import Base from '@/layouts/Base.astro';
import ServiceCard from '@/components/ServiceCard.astro';

const services = [
  {
    icon: '🤖',
    title: 'LLM & Agentic AI Systems',
    description:
      'End-to-end design and build of production LLM systems: RAG pipelines, tool-use and multi-agent orchestration, LLM evaluation frameworks, and fine-tuning with LoRA / QLoRA / Axolotl / Unsloth / TRL.',
    tags: ['RAG', 'Agents', 'Fine-tuning', 'LoRA', 'Evaluation', 'OpenAI', 'Gemini', 'Llama'],
  },
  {
    icon: '🔬',
    title: 'Biomedical & Pharma ML',
    description:
      'ML strategy and hands-on R&D for regulated, complex data environments — drug discovery, clinical evidence synthesis, diagnostics, and biomarker identification. I know how LLMs fail in these domains and how to work around it.',
    tags: ['Drug Discovery', 'Biomarker', 'Evidence Synthesis', 'Regulated Data', 'Pharma'],
  },
  {
    icon: '📝',
    title: 'NLP / NLG Pipelines',
    description:
      'Information extraction, question answering, search-intent classification, knowledge-base construction, and neural content generation. I built one of the very first production NLG content writers and know how to make them work at scale.',
    tags: ['NLP', 'NLG', 'Transformers', 'Intent Classification', 'Knowledge Graphs', 'SEO'],
  },
  {
    icon: '👁️',
    title: 'Computer Vision & Signal Processing',
    description:
      'Object detection, image classification, inventory automation, and BCI/EEG signal processing using OpenBCI and custom pipelines. From supermarket shelves to brain signals.',
    tags: ['CV', 'OpenCV', 'OpenBCI', 'EEG', 'Object Detection', 'CUDA'],
  },
  {
    icon: '💳',
    title: 'FinTech ML',
    description:
      'Alternative credit scoring for the unbanked using heterogeneous data sources, churn prediction, personalization engines, and ML-driven business decision systems for financial services.',
    tags: ['Credit Scoring', 'Churn', 'Personalization', 'Graph ML', 'FinTech'],
  },
  {
    icon: '📊',
    title: 'Traditional ML & Statistical Analysis',
    description:
      'The full ML toolkit beyond LLMs — gradient boosting, ensemble methods, time-series forecasting, clustering, survival analysis, and rigorous statistical modelling. I find the best solution for your problem, not just the trendiest one.',
    tags: ['XGBoost', 'Scikit-learn', 'Statistical Analysis', 'Time-series', 'Survival Analysis', 'R'],
  },
  {
    icon: '🛍️',
    title: 'Recommender Systems & E-commerce ML',
    description:
      'Large-scale recommendation engines for e-commerce and consumer apps — collaborative filtering, two-tower models, ranking systems, and real-time personalization pipelines at scale.',
    tags: ['Recommender Systems', 'Ranking', 'Personalization', 'Two-Tower', 'E-commerce', 'Shopify'],
  },
];

const engagements = [
  {
    type: 'Advisory Calls',
    icon: '💬',
    description:
      'A focused 60–90 min session to review your ML architecture, data science approach, or AI system design. Walk away with a concrete action plan.',
  },
  {
    type: 'Fixed-Scope Projects',
    icon: '🛠️',
    description:
      'Defined deliverable, defined timeline. Ideal for building a new ML model, designing a recommender system, running a statistical analysis, or evaluating an existing AI system.',
  },
];
---

<Base
  title="Consulting Services — Ahmed Dawod"
  description="Independent ML and data science consulting: recommender systems, statistical analysis, LLMs, Agentic AI, biomedical ML, NLP, CV, and FinTech. Available via direct engagement or the GLG Expert Network."
>
  <!-- Page hero -->
  <section class="bg-gradient-to-br from-slate-50 to-accent-50/30 dark:from-slate-900 dark:to-slate-900 pt-20 pb-16 px-4 sm:px-6 border-b border-slate-200 dark:border-slate-800">
    <div class="max-w-4xl mx-auto">
      <p class="font-mono text-accent-600 dark:text-accent-400 text-sm mb-3">Services</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-slate-900 dark:text-white mb-5">
        Consulting Services
      </h1>
      <p class="max-w-2xl text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        I help companies find and build the most effective ML solution for their problem — whether
        that's a rigorous statistical model, a large-scale recommender system, or a production LLM
        pipeline. 12+ years of experience means I know when to use each tool.
      </p>
    </div>
  </section>

  <!-- Who I work with -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Who I work with</h2>
    <p class="text-slate-600 dark:text-slate-400 leading-relaxed max-w-3xl">
      My consulting clients include e-commerce and consumer-tech companies that need large-scale
      recommender and ranking systems, pharma and biotech companies navigating AI in drug discovery,
      startups building LLM-powered products, content and SEO technology companies, and financial
      services firms exploring ML for underwriting and personalization. I've also consulted as an
      independent data scientist for academic research teams (published in Frontiers in Oncology).
    </p>
  </section>

  <!-- Services grid -->
  <section class="bg-slate-50 dark:bg-slate-800/30 py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-8">What I offer</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((s) => (
          <ServiceCard {...s} />
        ))}
      </div>
    </div>
  </section>

  <!-- Engagement models -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-8">Engagement models</h2>
    <div class="grid sm:grid-cols-2 gap-5">
      {engagements.map(({ type, icon, description }) => (
        <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6 bg-white dark:bg-slate-800/50">
          <div class="text-2xl mb-3">{icon}</div>
          <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-2">{type}</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- GLG Expert Network callout -->
  <section class="px-4 sm:px-6 pb-4">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-2xl border border-accent-200 dark:border-accent-800 bg-accent-50 dark:bg-accent-950/30 p-8">
        <div class="flex items-start gap-4">
          <div class="text-3xl shrink-0">🏛️</div>
          <div>
            <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100 mb-2">
              <a href="https://glg.com/" target="_blank" rel="noopener noreferrer" class="hover:text-accent-600 dark:hover:text-accent-400 transition-colors">
                GLG Research Expert Network ↗
              </a>
            </h3>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4">
              I am an invited member of the <strong class="font-medium text-slate-800 dark:text-slate-200">GLG (Gerson Lehrman Group) Research Expert Network</strong> —
              one of the world's leading expert networks used by investment firms, management
              consultancies, and Fortune 500 companies to access domain expertise.
            </p>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              Through GLG, I'm available for expert consultations on machine learning, LLMs, AI systems
              in regulated industries, and applied data science. If you're a GLG member, you can book
              me directly through the platform. For direct engagements, use the contact form.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Past consulting + CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-4">Published consulting work</h2>
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-2 max-w-2xl">
      As Data Science Consultant for AOA Dx, I contributed to biomarker research that led to a
      peer-reviewed publication in Frontiers in Oncology:
    </p>
    <a
      href="https://www.frontiersin.org/journals/oncology/articles/10.3389/fonc.2023.1134763/full"
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm text-accent-600 dark:text-accent-400 hover:underline"
    >
      GD2 and GD3 gangliosides as diagnostic biomarkers for all stages and subtypes of epithelial ovarian cancer →
    </a>

    <div class="mt-12 rounded-xl bg-slate-900 dark:bg-slate-800 p-8 text-center">
      <h3 class="text-lg font-semibold text-white mb-2">Ready to start?</h3>
      <p class="text-slate-400 text-sm mb-6">
        Drop me an email with a brief description of your problem and I'll get back to you within 48 hours.
      </p>
      <a
        href="/contact"
        class="inline-block px-6 py-3 rounded-lg bg-accent-500 hover:bg-accent-600 text-white font-semibold text-sm transition-colors"
      >
        Send a message
      </a>
    </div>
  </section>
</Base>
